# ──────────────────────────────────────────────────────────────────────────────
# Oliveto Contabilidade — Environment Variables
# Copy this file to .env and fill in the real values before running docker-compose
# ──────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Public base URL of the Oliveto API (exposed to the browser)
NEXT_PUBLIC_API_URL=https://api.oliveto.com.br

# Optional: server-side override (useful when API runs on the same Docker network)
# API_INTERNAL_URL=http://api:3001

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://oliveto.com.br
NEXT_PUBLIC_APP_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
# Client identification token sent in API requests
NEXT_PUBLIC_CLIENT_TOKEN=supersecretclienttoken

# Secret for on-demand ISR revalidation — min 32 characters
REVALIDATE_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
SENTRY_AUTH_TOKEN=sntrys_xxxxx

# ── reCAPTCHA v3 ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LdXXXXXXXXXXXXXXXXX
